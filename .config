# 核心架构设置 (x86_64)
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 磁盘大小建议 (Docker 占空间，设为 1.5GB)
CONFIG_TARGET_KERNEL_PARTSIZE=128
CONFIG_TARGET_ROOTFS_PARTSIZE=1536
CONFIG_TARGET_IMAGES_GZ=y

# 网页界面与中文语言包
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# --- 网络向导 (配置助手) ---
CONFIG_PACKAGE_luci-app-netwizard=y
CONFIG_PACKAGE_luci-i18n-netwizard-zh-cn=y

# --- Docker 相关插件 (Dockerman) ---
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_docker-ce=y

# --- 其他必备增强插件 ---
CONFIG_PACKAGE_luci-app-ttyd=y          # 网页终端
CONFIG_PACKAGE_luci-app-upnp=y          # 自动端口转发
CONFIG_PACKAGE_luci-app-turboacc=y      # 网络加速 (含 BBR/DNS 加速)
CONFIG_PACKAGE_luci-app-wol=y           # 网络唤醒 (远程开机)
# 移除一些可能冲突的拨号插件（可选，保持纯净）
# CONFIG_PACKAGE_luci-app-pppoe-server is not set

# 确保包含基本的网络工具
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-tun=y
